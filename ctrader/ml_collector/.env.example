# ─── Clean ML Data Collector — .env template ─────────────────────────────
# Copy to .env and fill in. Never commit .env with real credentials.
# chmod 600 .env after filling in.

# ─── cTrader app credentials (shared across all demo accounts) ──────────
# The same Client ID + Secret + Access Token work for every demo account
# linked to your cTrader Open API app. Per-bot account IDs go in ML_BOTS.
ML_CTRADER_CLIENT_ID=
ML_CTRADER_CLIENT_SECRET=
ML_CTRADER_ACCESS_TOKEN=
ML_CTRADER_REFRESH_TOKEN=

# Which demo account the price feed authenticates as. Any valid demo works —
# price data is account-agnostic once authed. Default: first bot's account.
# ML_PRICE_FEED_ACCOUNT_ID=

# ─── Safety: live account lock-out ───────────────────────────────────────
# Set this to your production live account ID. The collector refuses to
# start if any bot or the price feed points at this ID.
ML_FORBIDDEN_ACCOUNT_ID=0

# Fallback equity (USD) when cTrader balance fetch fails and no cached value
# is available. Used only for sizing; does not affect real-money behaviour.
ML_FALLBACK_BALANCE=10000

# ─── Database ─────────────────────────────────────────────────────────────
ML_DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>

# ─── Paths ────────────────────────────────────────────────────────────────
# ML_REPO_PATH: where the companion ml-data repo is checked out on the host
# ML_DATA_SUBDIR: subdir inside that repo this collector writes to
# ML_STATE_DIR:  runtime state (PID lock, open-trades snapshot)
ML_REPO_PATH=/path/to/ml-data-checkout
ML_DATA_SUBDIR=ml_data_clean
ML_STATE_DIR=/path/to/ml_collector/state

# ─── Git identity (scoped to the companion ml-data repo) ──────────────────
ML_GIT_USER_NAME=
ML_GIT_USER_EMAIL=

# ─── Loop cadence ─────────────────────────────────────────────────────────
ML_LOOP_INTERVAL_SECONDS=60
ML_POSITION_POLL_SECONDS=30

# ─── Bots (JSON array) ───────────────────────────────────────────────────
# name:           bot name (one of hydra/viper/mamba/taipan/cobra/anaconda)
# model:          one of the models in ensemble/models/
# timeframe:      m1 | m5 | m15 | m30 | h1 | h4
# tf_enum:        1 (m1) | 5 (m5) | 7 (m15) | 8 (m30) | 9 (h1) | 10 (h4)
# account_id:     cTrader demo account this bot trades on (DEMO, never live)
# lots:           fallback static lot size (used if notional_pct is 0)
# notional_pct:   adaptive sizing — target notional = balance × notional_pct
# min_confidence: BUY/SELL threshold (0–1)
# max_concurrent: max open positions per bot per symbol (keep at 1)
# bar_count:      historical bars to fetch on each evaluation
ML_BOTS='[
  {"name":"hydra",    "model":"mamba_reversion",  "timeframe":"m1",  "tf_enum":1,  "account_id":0, "lots":1.0, "notional_pct":1.0, "min_confidence":0.70, "max_concurrent":1, "bar_count":100},
  {"name":"viper",    "model":"momentum_hunter",  "timeframe":"m5",  "tf_enum":5,  "account_id":0, "lots":1.0, "notional_pct":1.0, "min_confidence":0.70, "max_concurrent":1, "bar_count":200},
  {"name":"mamba",    "model":"mamba_reversion",  "timeframe":"m15", "tf_enum":7,  "account_id":0, "lots":1.0, "notional_pct":1.0, "min_confidence":0.70, "max_concurrent":1, "bar_count":300},
  {"name":"taipan",   "model":"session_analyst",  "timeframe":"m30", "tf_enum":8,  "account_id":0, "lots":1.0, "notional_pct":1.0, "min_confidence":0.70, "max_concurrent":1, "bar_count":200},
  {"name":"cobra",    "model":"trend_follower",   "timeframe":"h1",  "tf_enum":9,  "account_id":0, "lots":1.0, "notional_pct":1.0, "min_confidence":0.70, "max_concurrent":1, "bar_count":200},
  {"name":"anaconda", "model":"volume_profiler",  "timeframe":"h4",  "tf_enum":10, "account_id":0, "lots":1.0, "notional_pct":1.0, "min_confidence":0.70, "max_concurrent":1, "bar_count":200}
]'

ML_SYMBOLS=EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,NZDUSD,USDCAD,GBPJPY,EURJPY,XAUUSD,XAGUSD,US500,GER40,UK100,JPN225

# ─── Observability ────────────────────────────────────────────────────────
ML_LOG_LEVEL=INFO
